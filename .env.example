# ── LLM / Model ──────────────────────────────────────────────────
ollama-api-key=
# ^ Your Ollama cloud API key from https://ollama.com

preconscious-key=
# ^ Separate API key for heartbeat/scheduled tasks

# ── Discord ──────────────────────────────────────────────────────
discord-token=
# ^ Discord bot token from https://discord.com/developers/applications

# ── Notion ───────────────────────────────────────────────────────
notion-key=
# ^ Notion internal integration token from https://www.notion.so/my-integrations

notion-default-page-id=
# ^ ID of the default parent page for new Notion pages

# ── Tavily (web search) ──────────────────────────────────────────
tavily-api-key=
# ^ Tavily search API key from https://app.tavily.com

# ── Obsidian (optional) ──────────────────────────────────────────
obsidian-host=http://127.0.0.1:27123
obsidian-api-key=
# ^ Obsidian Local REST API credentials

# ── Groq TTS (voice mode) ────────────────────────────────────────
groq-api-key=
# ^ Groq API key from https://console.groq.com/keys
