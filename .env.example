# ── LLM / Model ──────────────────────────────────────────────────
ollama-api-key=
# ^ Your Ollama cloud API key from https://ollama.com. Required for cloud model.

preconscious-key=
# ^ Separate API key for heartbeat/scheduled tasks. Independent of the main model key.

# ── Discord ──────────────────────────────────────────────────────
discord-token=
# ^ Discord bot token from https://discord.com/developers/applications

# ── Notion ───────────────────────────────────────────────────────
notion-key=
# ^ Notion internal integration token from https://www.notion.so/my-integrations

notion-default-page-id=
# ^ ID of the default parent page for new Notion pages (when no parent_page_id is given).

# ── GitHub ───────────────────────────────────────────────────────
github-token=
# ^ GitHub personal access token (classic or fine-grained) for git operations.

# ── Tavily (web search) ──────────────────────────────────────────
tavily-api-key=
# ^ Tavily search API key from https://app.tavily.com

# ── Obsidian (optional) ──────────────────────────────────────────
obsidian-host=http://127.0.0.1:27123
obsidian-api-key=
# ^ Obsidian Local REST API credentials. Host defaults to http://127.0.0.1:27123.
